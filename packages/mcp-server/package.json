{
  "name": "@voltbots/mcp-hivemind",
  "version": "0.1.0",
  "description": "MCP server for VoltBots Hivemind — works with Claude Desktop, Claude Code, and any MCP client",
  "type": "module",
  "bin": {
    "mcp-hivemind": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "echo 'no tests yet'",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@voltbots/hivemind": "*"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voltbots/voltbots-hivemind-sdk.git",
    "directory": "packages/mcp-server"
  },
  "keywords": [
    "voltbots",
    "hivemind",
    "mcp",
    "claude",
    "ai"
  ]
}
