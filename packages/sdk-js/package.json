{
  "name": "@voltbots/hivemind",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript SDK for the VoltBots Hivemind API",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/voltbots/voltbots-hivemind-sdk.git",
    "directory": "packages/sdk-js"
  },
  "keywords": [
    "voltbots",
    "hivemind",
    "ai",
    "mistakes",
    "code-review",
    "sdk"
  ]
}
